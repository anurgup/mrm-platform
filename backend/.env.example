# Copy to .env for LOCAL (non-Docker) development. Docker Compose sets
# these directly via docker-compose.yml's `environment:` block instead —
# this file is only consulted when running the app directly on your
# machine (uvicorn app.main:app --reload).

# APP_NAME="MRM Platform"
# ENVIRONMENT=development
# DATABASE_URL=sqlite:///./mrm.db
# CORS_ORIGINS=http://localhost:5173

# Optional, for future LLM integration (not read by any code path yet):
# ANTHROPIC_API_KEY=sk-ant-...
